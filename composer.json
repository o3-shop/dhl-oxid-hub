{
    "name": "o3-shop/o3-dhl",
    "type": "o3shop-module",
    "keywords": [
        "o3-shop",
        "modules",
        "eShop"
    ],
    "license": "proprietary",
    "config": {
        "platform": {
            "php": "7.4.33"
        },
        "prepend-autoloader": false,
        "vendor-dir": "src/modules/mo/mo_dhl/vendor",
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "require": {
        "php": ">=7.4",
        "monolog/monolog": "^1.12 || ^2.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "ext-calendar": "*",
        "ext-iconv": "*",
        "ext-soap": "*",
        "symfony/console": "^2.7||^3.1||^4.0||^5.0",
        "symfony/serializer": "^4.4",
        "symfony/options-resolver": "^4.4 || ^5.0 || ^6.0",
        "symfony/yaml": "^3.4 || ^4.4 || ^5.0 || ^6.0",
        "league/uri": "^6.5 || ^7.0",
        "php-jsonpointer/php-jsonpointer": "^3.0 || ^4.0",
        "php-http/client-common": "^2.0",
        "php-http/multipart-stream-builder": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "php-http/curl-client": "^2.2",
        "nyholm/psr7": "^1.5"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^7.5",
        "mjaschen/phpgeo": "^1.3",
        "fzaninotto/faker": "^1.7",
        "guzzlehttp/streams": "^3.0",
        "jane-php/open-api-3": "^7.5"
    },
    "extra": {
        "oxideshop": {
            "source-directory": "src/modules/mo/mo_dhl",
            "target-directory": "mo/mo_dhl"
        }
    },
    "autoload": {
        "psr-4": {
            "Mediaopt\\DHL\\": "src/modules/mo/mo_dhl",
            "Jane\\Component\\JsonSchemaRuntime\\": "src/modules/mo/mo_dhl/JaneRuntime/JsonSchemaRuntime",
            "Jane\\Component\\OpenApiRuntime\\": "src/modules/mo/mo_dhl/JaneRuntime/OpenApiRuntime"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
